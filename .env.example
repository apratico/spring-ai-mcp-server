# OpenAI API key — required ONLY by the search_manuals MCP tool, which embeds
# the maintenance-manual corpus into the in-memory vector store at startup.
# The other four MCP tools (production orders, telemetry, inventory, maintenance
# tickets) work without a key — leave both vars blank to keep them and skip RAG.
OPENAI_API_KEY=

# Set this to `openai` together with OPENAI_API_KEY to activate the embedding
# auto-configuration and register the search_manuals tool. Anything else (or
# unset) keeps every OpenAI model auto-config disabled.
SPRING_AI_MODEL_EMBEDDING=

